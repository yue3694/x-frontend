# Server-side URL of the Go service. Use the Docker service name in containers.
GO_API_URL=http://localhost:8080

# JWT signing secret (HS256). Use a 32+ byte random string in production.
AUTH_JWT_SECRET=dev-secret-change-me

# PostgreSQL connection string (Go backend reads this).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable