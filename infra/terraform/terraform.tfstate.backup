            ],
            "name": "x-frontend-production-pr-preview",
            "project_visibility": "PRIVATE",
            "public_project_alias": "",
            "queued_timeout": 480,
            "region": "ap-northeast-1",
            "resource_access_role": "",
            "secondary_artifacts": [],
            "secondary_source_version": [],
            "secondary_sources": [],
            "service_role": "arn:aws:iam::775086395318:role/x-frontend-production-pr-preview",
            "source": [
              {
                "auth": [],
                "build_status_config": [],
                "buildspec": "version: 0.2\n\n# Builds and (re)deploys a per-PR preview environment, then tears it down on\n# PULL_REQUEST_CLOSED. Source is NO_SOURCE so this buildspec does its own\n# git clone (the CodeBuild service in this account can't use CodeConnections).\n# The trigger Lambda (deployed separately) sets PR_NUMBER / PR_REF / PR_ACTION\n# via environment overrides on StartBuild.\nphases:\n  pre_build:\n    commands:\n      - set -eu\n      - test -n \"$PR_NUMBER\"\n      - |\n        export IMAGE_TAG=\"pr-${PR_NUMBER}-$(printf '%s' \"${PR_SHA:-manual}\" | cut -c1-12)-${CODEBUILD_BUILD_NUMBER}\"\n        if [ \"${PR_ACTION:-build}\" != \"closed\" ]; then\n          git clone --depth 1 \"$GITHUB_REPO_URL\" \"$CODEBUILD_SRC_DIR\"\n          cd \"$CODEBUILD_SRC_DIR\"\n          git fetch --depth 1 origin \"refs/pull/${PR_NUMBER}/head\"\n          git checkout --detach FETCH_HEAD\n          aws ecr get-login-password --region \"$AWS_REGION\" | docker login --username AWS --password-stdin \"$AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com\"\n          # Use ECR Public mirrors to avoid Docker Hub anonymous pull limits.\n          docker pull public.ecr.aws/docker/library/golang:1.25-alpine\n          docker tag public.ecr.aws/docker/library/golang:1.25-alpine golang:1.25-alpine\n          docker pull public.ecr.aws/docker/library/node:22-alpine\n          docker tag public.ecr.aws/docker/library/node:22-alpine node:22-alpine\n          docker pull public.ecr.aws/docker/library/alpine:3.21\n          docker tag public.ecr.aws/docker/library/alpine:3.21 alpine:3.21\n        fi\n  build:\n    commands:\n      - |\n        set -eu\n        if [ \"${PR_ACTION:-build}\" != \"closed\" ]; then\n          docker build -f Dockerfile.go -t \"$API_REPOSITORY:$IMAGE_TAG\" .\n          docker build -t \"$WEB_REPOSITORY:$IMAGE_TAG\" .\n          docker run --rm \\\n            -v \"$PWD/backend:/src\" -w /src \\\n            -e GOOS=linux -e GOARCH=amd64 -e CGO_ENABLED=0 \\\n            public.ecr.aws/docker/library/golang:1.25-alpine \\\n            go build -o tmp/bootstrap ./cmd/edge-lambda\n          docker build -f Dockerfile.lambda -t \"$LAMBDA_REPOSITORY:$IMAGE_TAG\" .\n          docker push \"$API_REPOSITORY:$IMAGE_TAG\"\n          docker push \"$WEB_REPOSITORY:$IMAGE_TAG\"\n          docker push \"$LAMBDA_REPOSITORY:$IMAGE_TAG\"\n        else\n          echo \"PR closed; skipping image build\"\n        fi\n  post_build:\n    commands:\n      - |\n        set -eu\n        if [ \"${PR_ACTION:-}\" = \"closed\" ]; then\n          api_service=\"pr-${PR_NUMBER}-api\"\n          web_service=\"pr-${PR_NUMBER}-web\"\n          host=\"pr-${PR_NUMBER}.${PREVIEW_DOMAIN}\"\n          for service in \"$api_service\" \"$web_service\"; do\n            if aws ecs describe-services --cluster \"$ECS_CLUSTER\" --services \"$service\" --query 'services[0].status' --output text 2\u003e/dev/null | grep -q ACTIVE; then\n              aws ecs update-service --cluster \"$ECS_CLUSTER\" --service \"$service\" --desired-count 0 \u003e/dev/null\n              aws ecs delete-service --cluster \"$ECS_CLUSTER\" --service \"$service\" --force \u003e/dev/null\n              aws ecs wait services-inactive --cluster \"$ECS_CLUSTER\" --services \"$service\"\n            fi\n          done\n          for listener in \"$ALB_LISTENER_ARN\" \"${ALB_HTTPS_LISTENER_ARN:-}\"; do\n            [ -z \"$listener\" ] \u0026\u0026 continue\n            for rule in $(aws elbv2 describe-rules --listener-arn \"$listener\" --query \"Rules[?Conditions[?Field=='host-header' \u0026\u0026 Values[0]=='${host}']].RuleArn\" --output text); do\n              aws elbv2 delete-rule --rule-arn \"$rule\"\n            done\n          done\n          target_group_arn=$(aws elbv2 describe-target-groups --names \"$web_service\" --query 'TargetGroups[0].TargetGroupArn' --output text 2\u003e/dev/null || true)\n          if [ \"$target_group_arn\" != \"None\" ] \u0026\u0026 [ -n \"$target_group_arn\" ]; then\n            for attempt in 1 2 3 4 5 6; do\n              aws elbv2 delete-target-group --target-group-arn \"$target_group_arn\" 2\u003e/dev/null \u0026\u0026 break\n              sleep 10\n            done\n          fi\n          cloud_map_id=$(aws servicediscovery list-services --query \"Services[?Name=='${api_service}'].Id | [0]\" --output text)\n          if [ \"$cloud_map_id\" != \"None\" ] \u0026\u0026 [ -n \"$cloud_map_id\" ]; then\n            for attempt in 1 2 3 4 5 6; do\n              aws servicediscovery delete-service --id \"$cloud_map_id\" 2\u003e/dev/null \u0026\u0026 break\n              sleep 10\n            done\n          fi\n          record=$(curl -fsS \"https://api.cloudflare.com/client/v4/zones/${CLOUDFLARE_ZONE_ID}/dns_records?type=CNAME\u0026name=${host}\" -H \"Authorization: Bearer ${CLOUDFLARE_TOKEN}\" | jq -r '.result[0].id // empty')\n          if [ -n \"$record\" ]; then\n            curl -fsS -X DELETE \"https://api.cloudflare.com/client/v4/zones/${CLOUDFLARE_ZONE_ID}/dns_records/${record}\" -H \"Authorization: Bearer ${CLOUDFLARE_TOKEN}\" \u003e/dev/null\n          fi\n          echo \"Preview removed: ${host}\"\n        elif [ \"${CODEBUILD_BUILD_SUCCEEDING:-0}\" = \"1\" ]; then\n          # PR branches can contain an older deployment helper. Associate the\n          # target group here before that helper calls ECS CreateService.\n          web_service=\"pr-${PR_NUMBER}-web\"\n          host=\"pr-${PR_NUMBER}.${PREVIEW_DOMAIN}\"\n          target_group_arn=$(aws elbv2 describe-target-groups --names \"$web_service\" --query 'TargetGroups[0].TargetGroupArn' --output text 2\u003e/dev/null || true)\n          if [ \"$target_group_arn\" = \"None\" ] || [ -z \"$target_group_arn\" ]; then\n            target_group_arn=$(aws elbv2 create-target-group --name \"$web_service\" --protocol HTTP --port 3000 --target-type ip --vpc-id \"$VPC_ID\" --health-check-path / --matcher HttpCode=200-399 --query 'TargetGroups[0].TargetGroupArn' --output text)\n          fi\n          if ! aws elbv2 describe-rules --listener-arn \"$ALB_LISTENER_ARN\" --query \"Rules[?Conditions[?Field=='host-header' \u0026\u0026 Values[0]=='${host}']] | length(@)\" --output text | grep -q '^1$'; then\n            priority=$((1000 + PR_NUMBER))\n            aws elbv2 create-rule --listener-arn \"$ALB_LISTENER_ARN\" --priority \"$priority\" --conditions \"Field=host-header,Values=${host}\" --actions \"Type=forward,TargetGroupArn=${target_group_arn}\" \u003e/dev/null\n          fi\n          if [ -n \"${ALB_HTTPS_LISTENER_ARN:-}\" ] \u0026\u0026 ! aws elbv2 describe-rules --listener-arn \"$ALB_HTTPS_LISTENER_ARN\" --query \"Rules[?Conditions[?Field=='host-header' \u0026\u0026 Values[0]=='${host}']] | length(@)\" --output text | grep -q '^1$'; then\n            priority=$((1000 + PR_NUMBER))\n            aws elbv2 create-rule --listener-arn \"$ALB_HTTPS_LISTENER_ARN\" --priority \"$priority\" --conditions \"Field=host-header,Values=${host}\" --actions \"Type=forward,TargetGroupArn=${target_group_arn}\" \u003e/dev/null\n          fi\n          bash infrastructure/scripts/deploy-pr-preview.sh \"$PR_NUMBER\" \"$IMAGE_TAG\"\n        else\n          echo \"Image build failed; preview deployment skipped\"\n          exit 1\n        fi\n",
                "git_clone_depth": 0,
                "git_submodules_config": [],
                "insecure_ssl": false,
                "location": "",
                "report_build_status": false,
                "type": "NO_SOURCE"
              }
            ],
